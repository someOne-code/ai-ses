{
  "name": "ai-ses-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "import:listings": "tsx scripts/import-listings.ts",
    "seed:local-demo": "tsx scripts/seed-local-demo.ts",
    "smoke:n8n-booking-workflow": "node --import tsx --test test/n8n-booking-runtime-smoke.test.ts",
    "smoke:n8n-booking-google-calendar": "node --import tsx --test test/n8n-booking-runtime-smoke.test.ts --test-name-pattern \"Google Calendar\"",
    "smoke:n8n-crm-workflow": "node --import tsx --test test/n8n-crm-runtime-smoke.test.ts",
    "smoke:n8n-local-chain": "node --import tsx --test test/n8n-chained-runtime-smoke.test.ts",
    "smoke:gemini-embedding": "tsx scripts/gemini-embedding-smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.3",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.16.3",
    "retell-sdk": "^5.10.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.1.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
