        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"officeId\": \"{{ $('Normalize Dispatch').item.json.officeId }}\",\n  \"connectionId\": \"{{ $('Normalize Dispatch').item.json.connectionId }}\",\n  \"entityType\": \"{{ $('Normalize Dispatch').item.json.entityType }}\",\n  \"entityId\": \"{{ $('Normalize Dispatch').item.json.entityId }}\",\n  \"eventType\": \"{{ $('Normalize Dispatch').item.json.eventType }}\",\n  \"deliveryStatus\": \"failed\",\n  \"workflowRunId\": \"{{ $execution.id }}\",\n  \"note\": {{ JSON.stringify((() => { const fallback = 'CRM delivery failed.'; const candidates = [$json.message, $json.error?.message, $json.errorMessage, $json.error, fallback].filter((value) => typeof value === 'string' && value.trim() !== ''); for (const candidate of candidates) { const trimmed = candidate.trim(); const separatorIndex = trimmed.indexOf(' - '); const normalized = separatorIndex === -1 ? trimmed : trimmed.slice(separatorIndex + 3); const variants = [normalized]; try { variants.push(JSON.parse(normalized)); } catch {} for (const variant of variants) { if (variant && typeof variant === 'object' && typeof variant.message === 'string' && variant.message.trim() !== '') return variant.message; if (typeof variant === 'string') { try { const parsed = JSON.parse(variant); if (parsed && typeof parsed.message === 'string' && parsed.message.trim() !== '') return parsed.message; } catch {} } } } return fallback; })()) }},\n  \"payload\": {\n    \"deliveryResponse\": {{ JSON.stringify($json) }}\n  }\n}\n",
        "options": {}
